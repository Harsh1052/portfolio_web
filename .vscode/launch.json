{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    // ─── WEB — CanvasKit (default in Flutter 3.22+) ───────────────────────────
    {
      "name": "Portfolio Web (Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "program": "lib/main.dart"
    },
    {
      "name": "Portfolio Web (Profile)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "profile",
      "program": "lib/main.dart"
    },
    {
      "name": "Portfolio Web (Release)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "release",
      "program": "lib/main.dart"
    },
    // ─── WEB — Skwasm / WASM (Flutter 3.22+, faster on supported browsers) ───
    {
      "name": "Portfolio Web — WASM (Debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "program": "lib/main.dart",
      "args": [
        "--wasm"
      ]
    },
    {
      "name": "Portfolio Web — WASM (Release)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "release",
      "program": "lib/main.dart",
      "args": [
        "--wasm"
      ]
    },
    // ─── TESTS ────────────────────────────────────────────────────────────────
    {
      "name": "Run All Tests",
      "request": "launch",
      "type": "dart",
      "program": "test",
      "args": [
        "--coverage"
      ]
    }
  ]
}