rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Visitor counter — public read + public write for the stats doc only.
    // Field validation kept simple to avoid subtle rule eval issues with
    // server-side transforms (FieldValue.increment / serverTimestamp).
    match /visitors/stats {
      allow read: if true;
      allow write: if true;
    }

    // Visitor locations — public read + public create. No update or delete allowed for security.
    match /visitor_locations/{locationId} {
      allow read, create: if true;
    }

    // All other documents — deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
